[Unit]
Description=HOA Oracle API
After=network.target

[Service]
Type=simple
User=abeall
WorkingDirectory=/home/abeall/hoa-oracle
EnvironmentFile=/home/abeall/hoa-oracle/.env
ExecStart=/home/abeall/hoa-oracle/.venv/bin/uvicorn app.main:app --host 0.0.0.0 --port 8000
Restart=on-failure
RestartSec=5
StandardOutput=journal
StandardError=journal

[Install]
WantedBy=multi-user.target
